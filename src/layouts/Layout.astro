---
const { title = "Vaikne Laine OÜ" } = Astro.props;
const nav = [
  { label: "Avaleht", href: "/" },
  { label: "Uudised", href: "/uudised" },
  { label: "Kontakt", href: "/kontakt" },
];
---
<!doctype html>
<html lang="et">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="logo" href="/">Vaikne Laine</a>
      <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
      <label for="nav-toggle" class="nav-toggle-label" aria-label="Ava menüü">☰</label>
      <nav>{nav.map((item) => <a href={item.href}>{item.label}</a>)}</nav>
    </header>
    <main><slot /></main>
    <footer class="site-footer">
      <p>© {new Date().getFullYear()} Vaikne Laine OÜ · mööblirestaureerimise töökoda</p>
    </footer>
    <style is:global>
      :root { --brand:#3a4a3f; --accent:#b07d52; --bg:#f6f2ea; --text:#22231f; }
      * { box-sizing:border-box; }
      body { margin:0; font-family:system-ui,sans-serif; background:var(--bg); color:var(--text); line-height:1.6; }
      .site-header { position:relative; display:flex; align-items:center; justify-content:space-between; padding:1rem 2rem; background:var(--brand); color:#fff; }
      .logo { color:#fff; font-weight:700; font-size:1.25rem; text-decoration:none; letter-spacing:0.02em; }
      .site-header nav { display:flex; gap:1.5rem; }
      .site-header nav a { color:#fff; text-decoration:none; }
      .site-header nav a:hover { text-decoration:underline; }
      .nav-toggle-label { display:none; cursor:pointer; font-size:1.6rem; line-height:1; user-select:none; }
      main { max-width:860px; margin:0 auto; padding:2rem 1.5rem; }
      .site-footer { text-align:center; padding:2rem 1.5rem; color:#6b6b6b; font-size:0.9rem; }
      h1 { color:var(--brand); }
      img { max-width:100%; height:auto; border-radius:8px; }
      a { color:var(--accent); }
      @media (max-width: 640px) {
        .nav-toggle-label { display:block; }
        .site-header nav { display:none; }
        .nav-toggle:checked ~ nav { display:flex; flex-direction:column; gap:1rem; position:absolute; right:1rem; top:3.6rem; background:var(--brand); padding:1rem 1.25rem; border-radius:8px; box-shadow:0 6px 18px rgba(0,0,0,0.2); z-index:10; }
      }
    </style>
  </body>
</html>
